{
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorCustomizations": {
    "activityBar.background": "#2d5805",
    "activityBar.foreground": "#d6e6ff",
    "activityBarBadge.background": "#3498db",
    "activityBarBadge.foreground": "#2d5805",
    "statusBar.background": "#2d5805",
    "statusBar.foreground": "#d6e6ff",
    "titleBar.activeBackground": "#2d5805",
    "titleBar.activeForeground": "#ffffff"
  },
  "editor.tabSize": 4,
  "editor.rulers": [
    88
  ],
  "editor.renderWhitespace": "boundary",
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "python.languageServer": "Default",
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.autoImportCompletions": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true,
  "python.terminal.useEnvFile": true,
  "terminal.integrated.shellIntegration.enabled": false,
  "python.testing.pytestEnabled": false,
  "python.testing.unittestEnabled": false,
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.pyo": true
  },
  "git.autofetch": true
}